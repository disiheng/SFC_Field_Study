
#include <stdio.h>
#include <stdlib.h>
#include <math.h>
#include <time.h>
#include <assert.h>
#include <mpi.h>

#include <srfftw_mpi.h>

//#include "allvars.h"
#include "../utils/mymalloc.h"
#include "../utils/gadget.h"
#include "../utils/utils.h"
#include "power.h"

#define ASMTH 1.25

#define CUB(x) (x*x*x)
#define dbg1 0
#define dbg2 0

//#ifndef PARTICLE_TYPE
//#define PARTICLE_TYPE 1+2+4+8+16+32 
//#endif
//extern int Ngrid, Ngrid2;
extern time_t t0;
extern int ThisTask, NTasks;

//extern int *slab_to_task, *slab_to_task_local, *slabs_per_task, *first_slab_of_task;

void power(char fname[], Grid grid, int nfold, float boxsize)
{
  long long i, j, k, ii, jj, kk, x, y, z, zz;
  int bin;
  double fx, fy, fz, ff, po;
  long long ip;
  long l, m, n, nbin;
  long long ijk, le, me, ne;
  unsigned long *nx;
  long long id = 0, id2;
  double norm;
  double pk, k2, kx, ky, kz, deltak;
  char buf[255];
  double ktot, Sk, ak, bk, k_nyquist;
  double kpar, kper;
  double mode, fac, smth, Asmth;
  double K0, K1, binfac;
  int rep;
  int BINS_PS;

  static fftw_complex *fft_of_rhogrid;
  static fftw_real *rhogrid, *forcegrid, *workspace;

  static rfftwnd_mpi_plan fft_forward_plan, fft_inverse_plan;
  static int fftsize, maxfftsize, dimprodmax;

  double *SumPower, *Kbin;
  long long *CountModes;
  double *powerbuf, *kbinbuf;
  long long *countbuf;



  int local_x_start, local_nx, local_y_start, local_ny, total_local_size;

  MSG0(" Creating plan for %d cells", t0, ThisTask, grid.Ngrid);

  fft_forward_plan = rfftw3d_mpi_create_plan(MPI_COMM_WORLD, grid.Ngrid, grid.Ngrid, grid.Ngrid, 
                                             FFTW_REAL_TO_COMPLEX, FFTW_ESTIMATE | FFTW_IN_PLACE | FFTW_THREADSAFE);

  fft_inverse_plan = rfftw3d_mpi_create_plan(MPI_COMM_WORLD, grid.Ngrid, grid.Ngrid, grid.Ngrid, 
                                             FFTW_COMPLEX_TO_REAL, FFTW_ESTIMATE | FFTW_IN_PLACE | FFTW_THREADSAFE);

  rfftwnd_mpi_local_sizes(fft_forward_plan, &local_nx, &local_x_start, &local_ny, &local_y_start, &fftsize);


  MPI_Allreduce(&fftsize, &maxfftsize, 1, MPI_INT, MPI_MAX, MPI_COMM_WORLD);

  rhogrid = (fftw_real *) mymalloc_movable(&rhogrid,"rhogrid",fftsize * sizeof(fftw_real));


  for(i = 0; i < fftsize; i++)	/* clear local density field */
    rhogrid[i] = 0;

  double NumPart = 0, TotNumPart = 0;
  for(i = 0; i < grid.local_nx; i++)
    {
      for(j = 0; j < grid.Ngrid; j++)
	{
	  for(k = 0; k < grid.Ngrid; k++)
	    {
	      ijk = k + grid.Ngrid * (j + grid.Ngrid * i);
	      rhogrid[(i * grid.Ngrid + j) * (2 * (grid.Ngrid / 2 + 1)) + k] = (fftw_real) grid.data[ijk];
              assert((i * grid.Ngrid + j) * (2 * (grid.Ngrid / 2 + 1)) + k < maxfftsize);
	      NumPart += grid.data[ijk];
	      //if (grid.data[ijk] > 0)
	      //printf("%f\n",grid.data[ijk]);
	    }
	}
    }

  myfree_movable(grid.data);

  fft_of_rhogrid = (fftw_complex *) & rhogrid[0];
  workspace = (fftw_real *) mymalloc_movable(&workspace,"workspace",maxfftsize * sizeof(fftw_real));
  for(i = 0; i < fftsize; i++)	/* clear local density field */
    workspace[i] = 0;


  MPI_Allreduce(&NumPart, &TotNumPart, 1, MPI_DOUBLE, MPI_SUM, MPI_COMM_WORLD);
  MSG0(" %f Particles in a  box of side %f", t0, ThisTask,NumPart, boxsize);
  MSG0("Total %f Particles ", t0, ThisTask, TotNumPart);
  assert(TotNumPart > 0);
  assert(boxsize > 0);

  MSG0(" FFT", t0, ThisTask);
  rfftwnd_mpi(fft_forward_plan, 1, rhogrid, workspace, FFTW_TRANSPOSED_ORDER);
  MSG0(" FFT done", t0, ThisTask);

  fac = 1. / TotNumPart;
  K0 = 2 * M_PI / boxsize;	/* minimum k */
  //binfac = 1./K0;
 // K1 = 10;
//  BINS_PS = (K1-K0)*binfac;
  
  BINS_PS = grid.Ngrid;

  //linear bins
  K1 = K0 + BINS_PS*K0;		/* maximum k */
  binfac = BINS_PS / (K1 - K0);

  //logs bins
  //BINS_PS = grid.Ngrid/10;
  //binfac = BINS_PS / (log(K1) - log(K0));
  

  SumPower   = mymalloc("SumPower",BINS_PS * sizeof(double));
  CountModes = mymalloc("CountModes",BINS_PS * sizeof(long long));
  Kbin       = mymalloc("Kbin",BINS_PS * sizeof(long long));

  countbuf = mymalloc("countbuf",NTasks * BINS_PS * sizeof(long long));
  powerbuf = mymalloc("powerbuf",NTasks * BINS_PS * sizeof(double));
  kbinbuf  = mymalloc("kbinbuf",NTasks * BINS_PS * sizeof(double));

  for(i = 0; i < BINS_PS; i++)
    {
      SumPower[i] = 0.0;
      CountModes[i] = 0;
      Kbin[i] = 0;
    }

  MSG0(" Mode Counting", t0, ThisTask);
  printf("%d %d %d\n",ThisTask, grid.local_y_start, grid.local_ny);
  for(y = grid.local_y_start; y < grid.local_y_start + grid.local_ny; y++)
    for(x = 0; x < grid.Ngrid; x++)
      for(z = 0; z < grid.Ngrid / 2 + 1; z++)
	{
	  zz = z;
	  if(z >= grid.Ngrid / 2 + 1)
	    zz = grid.Ngrid - z;

	  if(x > grid.Ngrid / 2)
	    kx = x - grid.Ngrid;
	  else
	    kx = x;
	  if(y > grid.Ngrid / 2)
	    ky = y - grid.Ngrid;
	  else
	    ky = y;
	  if(z > grid.Ngrid / 2)
	    kz = z - grid.Ngrid;
	  else
	    kz = z;

	  k2 = kx * kx + ky * ky + kz * kz;

	  if(k2 > 0)
	    {
	      if(k2 < (grid.Ngrid / 2.0) * (grid.Ngrid / 2.0))
		{
		  // do deconvolution 

		  fx = fy = fz = 1;
		  if(kx != 0)
		    {
		      fx = (M_PI * kx) / grid.Ngrid;
		      fx = sin(fx) / fx;
		    }
		  if(ky != 0)
		    {
		      fy = (M_PI * ky) / grid.Ngrid;
		      fy = sin(fy) / fy;
		    }
		  if(kz != 0)
		    {
		      fz = (M_PI * kz) / grid.Ngrid;
		      fz = sin(fz) / fz;
		    }
		  ff = 1 / (fx * fy * fz);
		  smth = ff * ff;	
#ifdef CIC                 
                  smth = ff * ff * ff * ff;
#endif 
		  // end deconvolution 

		  ip = grid.Ngrid * (grid.Ngrid / 2 + 1) * (y - grid.local_y_start) + (grid.Ngrid / 2 + 1) * x + zz;

		  po = (fft_of_rhogrid[ip].re * fft_of_rhogrid[ip].re + fft_of_rhogrid[ip].im * fft_of_rhogrid[ip].im);

		  po *= fac * fac * smth;

		  mode = sqrt(k2) * 2 * M_PI / boxsize;

		  bin = (mode - K0) * binfac;
		  //bin = log(mode / K0) * binfac;
		  if(bin >= 0 && bin < BINS_PS)
		    {

		      SumPower[bin] += po;
		      CountModes[bin] += 1;
		      Kbin[bin] += mode;

		    }
		}
	    }
	}


  MPI_Allgather(CountModes, BINS_PS, MPI_LONG_LONG, countbuf, BINS_PS, MPI_LONG_LONG, MPI_COMM_WORLD);
  MPI_Allgather(SumPower, BINS_PS * sizeof(double), MPI_BYTE, powerbuf, BINS_PS * sizeof(double), MPI_BYTE, MPI_COMM_WORLD);
  MPI_Allgather(Kbin, BINS_PS * sizeof(double), MPI_BYTE, kbinbuf, BINS_PS * sizeof(double), MPI_BYTE, MPI_COMM_WORLD);

  for(i = 0; i < BINS_PS; i++)
    {
      CountModes[i] = 0;
      SumPower[i] = 0;
      Kbin[i] = 0;
      for(n = 0; n < NTasks; n++)
      {
	CountModes[i] += countbuf[n * BINS_PS + i];
	SumPower[i] += powerbuf[n * BINS_PS + i];
	Kbin[i] += kbinbuf[n * BINS_PS + i];
      }
    }

  for(i = 0; i < BINS_PS; i++)
    {
      //printf("%f %f\n",Kbin[i], SumPower[i]);
      if(CountModes[i] > 0)
	{
	  Kbin[i] = Kbin[i] / CountModes[i];
	  SumPower[i] = SumPower[i] / CountModes[i] * 4 * M_PI * CUB(Kbin[i]) * CUB(boxsize / 2 / M_PI);
	}
    }

  if(ThisTask == 0)
    {
      FILE *fd;
      char buf[255];
#ifdef PARTICLE_TYPE
      sprintf(buf, "%s_pk.pt_%d.%d.%d.fold%d", fname, PARTICLE_TYPE, grid.Ngrid, flag_redshift, nfold);
#else
      sprintf(buf, "%s_pk.%d.%d.fold%d", fname, grid.Ngrid, flag_redshift, nfold);
#endif
      printf("%s\n", buf);
      fd = my_fopen(buf, "w");
      for(i = 0; i < BINS_PS; i++)
	{
	  if(CountModes[i] > 0)
	    {
//	      printf("%d %f %f\n", i, Kbin[i], CountModes[i]);
	      fprintf(fd, "%f %f\n", Kbin[i], SumPower[i]);
	    }
	}
      fclose(fd);
    }

  myfree(kbinbuf);
  myfree(powerbuf);
  myfree(countbuf);

  myfree(Kbin);
  myfree(CountModes);
  myfree(SumPower);


  myfree_movable(workspace);
  myfree_movable(rhogrid);

  rfftwnd_mpi_destroy_plan(fft_forward_plan);
  rfftwnd_mpi_destroy_plan(fft_inverse_plan);

}


